#include <SdFat.h>

// Assigning pins
#define SD_CS    5    
#define SD_MOSI 23
#define SD_MISO 19
#define SD_SCLK 18

// Module declaration
SdFat SD;

void setup() {
  Serial.begin(115200);
  delay(1000);
  
  // Error checking
  if (!SD.begin(SdSpiConfig(SD_CS, DEDICATED_SPI, SD_SCK_MHZ(10)))) {
    Serial.println("Error!");
    return;
  }
  
  // Creating a file object
  File myFile;
  
  // Create a file
  if (myFile.open("hello.txt", FILE_WRITE)) {
    // We write the message "Hello" to the file
    myFile.println("Hello)");
    // Close the file (important! Otherwise, the data may not be saved)
    myFile.close();
    
    }
  // If you couldn't open/create a file, this is an error.
  else {
    Serial.println("Failed to create file!");
    Serial.print("Error code: ");
    Serial.println(SD.sdErrorCode());
  }
   
}

void loop() {
}
